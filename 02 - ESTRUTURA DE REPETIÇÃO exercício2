import java.util.Scanner;

import java.util.Scanner;

import java.util.Scanner;

public class Main {
    public static void main(String[] args) {

        Scanner input = new Scanner(System.in);

        int idade;
        int contador = 0;

        for(int i = 0; i < 10; i++)
        {
            System.out.println("Digite a idade:");
            idade = input.nextInt();

            if(idade >= 18)
            {
                contador++;
            }
        }

        System.out.println("Quantidade de pessoas com 18 anos ou mais: " + contador);
    }
}

